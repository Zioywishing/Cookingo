{
  "name": "Cookingo",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "bun run --bun nuxt build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run server/db/migrate.ts",
    "db:seed": "bun run server/db/seed/index.ts",
    "dev": "bun run --bun nuxt dev",
    "generate": "nuxt generate",
    "preview": "bun run --bun nuxt preview",
    "test": "bun test",
    "postinstall": "nuxt prepare",
    "quality-check": "bunx tsc --noEmit && bunx oxlint"
  },
  "dependencies": {
    "@paralleldrive/cuid2": "^2.3.1",
    "@nuxt/eslint": "1.15.2",
    "drizzle-orm": "^0.44.7",
    "jose": "^6.1.0",
    "nuxt": "^4.4.2",
    "vue": "^3.5.30",
    "vue-router": "^5.0.4",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vue/language-core": "^3.2.6",
    "bun-types": "^1.3.11",
    "drizzle-kit": "^0.31.5",
    "vue-tsc": "^3.2.6"
  }
}
